{
  "id": "effect_request_mixed_armor_status_damage_heal_atomic_success",
  "schema_version": 1,
  "godot_reference": [
    "scripts/sim/effect_runner.gd"
  ],
  "intent": "Armor, status, damage, and heal payloads can succeed atomically in payload order.",
  "operation": "apply_effect_request",
  "effect_request": {
    "source": { "player_id": 0, "source_unit_id": 1, "source_card_id": "fixture_card", "source_effect_id": "fixture_effect" },
    "target": { "target_unit_id": 2 },
    "payloads": [
      {
        "operation": "armor_effect",
        "armor_effect": { "operation": "add_current_armor", "amount": 1, "source_reason": "fixture" }
      },
      {
        "operation": "status_effect",
        "status_effect": { "operation": "apply_status", "status_id": "Burn", "duration": 2, "source_reason": "fixture" }
      },
      {
        "operation": "damage_effect",
        "damage_effect": { "amount": 3, "bypass_armor": false, "damage_cause": "Effect", "source_reason": "fixture" }
      },
      {
        "operation": "heal_effect",
        "heal_effect": { "amount": 2, "source_reason": "fixture" }
      }
    ]
  },
  "initial_state": {
    "current_player": 0,
    "priority_player": 0,
    "turn_number": 8,
    "phase": "normal_turn",
    "players": [
      { "player_id": 0, "remaining_mp": 2 },
      { "player_id": 1, "remaining_mp": 0 }
    ],
    "units": [
      { "id": 1, "owner_id": 0, "card_id": "fixture_source", "x": 4, "y": 4, "hp": 5, "max_hp": 5 },
      { "id": 2, "owner_id": 1, "card_id": "fixture_target", "x": 5, "y": 4, "hp": 5, "max_hp": 5, "current_armor": 1, "max_armor": 3 }
    ],
    "walls": [],
    "statuses_by_unit": {}
  },
  "expected": {
    "ok": true,
    "expected_trace_order": [ "effect_request_resolved", "armor_modified", "status_modified", "damage_effect_resolved", "heal_effect_resolved" ],
    "final_units": [
      { "id": 1, "x": 4, "y": 4, "hp": 5, "max_hp": 5, "statuses": [] },
      { "id": 2, "x": 5, "y": 4, "hp": 5, "max_hp": 5, "current_armor": 0, "max_armor": 3, "statuses": [ "Burn" ], "status_turns": { "Burn": 2 } }
    ],
    "trace_fields": [
      { "kind": "effect_request_resolved", "target_unit_id": 2 },
      { "kind": "armor_modified", "target_unit_id": 2, "previous_armor": 1, "new_armor": 2 },
      { "kind": "status_modified", "target_unit_id": 2, "status_id": "Burn", "new_status_turns": 2 },
      { "kind": "damage_effect_resolved", "target_unit_id": 2, "previous_hp": 5, "new_hp": 4, "previous_armor": 2, "new_armor": 0 },
      { "kind": "heal_effect_resolved", "target_unit_id": 2, "previous_hp": 4, "new_hp": 5, "effective_heal_amount": 1 }
    ]
  }
}
