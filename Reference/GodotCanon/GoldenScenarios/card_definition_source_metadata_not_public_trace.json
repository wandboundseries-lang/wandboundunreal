{
  "id": "card_definition_source_metadata_not_public_trace",
  "schema_version": 1,
  "godot_reference": [
    "scripts/data/CardDB/",
    "autoload/Game.gd",
    "scripts/sim/effect_runner.gd"
  ],
  "intent": "Definition source metadata can build and apply a card activation command without leaking source card/effect/debug ids or hidden zone cards into public traces.",
  "operation": "build_and_apply_card_activation_command",
  "card_definition": {
    "card_id": "secret_definition_card_token",
    "public_name": "Fixture Secret",
    "kind": "fixture",
    "activated_effects": [
      {
        "effect_id": "secret_definition_effect_token",
        "public_label": "Secret Damage Heal",
        "target_requirement": "unit",
        "payloads": [
          {
            "operation": "damage_effect",
            "damage_effect": { "amount": 2, "bypass_armor": true, "damage_cause": "Effect", "source_reason": "fixture" }
          },
          {
            "operation": "heal_effect",
            "heal_effect": { "amount": 1, "source_reason": "fixture" }
          }
        ]
      }
    ]
  },
  "activation_request": {
    "player_id": 0,
    "source_unit_id": 1,
    "effect_id": "secret_definition_effect_token",
    "target": { "target_unit_id": 2 },
    "debug_activation_id": "secret_definition_debug_token"
  },
  "initial_state": {
    "current_player": 0,
    "priority_player": 0,
    "turn_number": 9,
    "phase": "normal_turn",
    "players": [
      {
        "player_id": 0,
        "remaining_mp": 2,
        "deck": [ "secret_deck_card_token" ],
        "hand": [ "secret_hand_card_token" ],
        "discard": [ "secret_discard_card_token" ]
      },
      { "player_id": 1, "remaining_mp": 0 }
    ],
    "units": [
      { "id": 1, "owner_id": 0, "card_id": "fixture_source", "x": 4, "y": 4, "hp": 5, "max_hp": 5 },
      { "id": 2, "owner_id": 1, "card_id": "fixture_target", "x": 5, "y": 4, "hp": 5, "max_hp": 5 }
    ],
    "walls": [],
    "statuses_by_unit": {}
  },
  "expected": {
    "ok": true,
    "expected_trace_order": [ "card_activation_resolved", "effect_request_resolved", "damage_effect_resolved", "heal_effect_resolved" ],
    "final_units": [
      { "id": 1, "x": 4, "y": 4, "hp": 5, "max_hp": 5, "statuses": [] },
      { "id": 2, "x": 5, "y": 4, "hp": 4, "max_hp": 5, "statuses": [] }
    ],
    "trace_fields": [
      { "kind": "card_activation_resolved", "player_id": 0, "source_unit_id": 1, "target_unit_id": 2 },
      { "kind": "effect_request_resolved", "player_id": 0, "source_unit_id": 1, "target_unit_id": 2 },
      { "kind": "damage_effect_resolved", "player_id": 0, "source_unit_id": 1, "target_unit_id": 2, "damage_amount": 2, "previous_hp": 5, "new_hp": 3 },
      { "kind": "heal_effect_resolved", "player_id": 0, "source_unit_id": 1, "target_unit_id": 2, "previous_hp": 3, "new_hp": 4, "effective_heal_amount": 1 }
    ],
    "forbidden_substrings": [
      "secret_definition_card_token",
      "secret_definition_effect_token",
      "secret_definition_debug_token",
      "secret_deck_card_token",
      "secret_hand_card_token",
      "secret_discard_card_token"
    ]
  }
}
