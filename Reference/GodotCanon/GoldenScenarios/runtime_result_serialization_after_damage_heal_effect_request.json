{
  "id": "runtime_result_serialization_after_damage_heal_effect_request",
  "schema_version": 1,
  "godot_reference": [
    "scripts/sim/effect_runner.gd"
  ],
  "intent": "A utility runtime result envelope after a damage/heal effect request exposes public HP changes without hidden source or zone data.",
  "operation": "apply_effect_request",
  "effect_request": {
    "source": {
      "player_id": 0,
      "source_unit_id": 1,
      "source_card_id": "secret_source_card_token",
      "source_effect_id": "secret_source_effect_token"
    },
    "target": { "target_unit_id": 2 },
    "payloads": [
      {
        "operation": "damage_effect",
        "damage_effect": { "amount": 2, "bypass_armor": false, "damage_cause": "Effect", "source_reason": "fixture" }
      },
      {
        "operation": "heal_effect",
        "heal_effect": { "amount": 1, "source_reason": "fixture" }
      }
    ]
  },
  "initial_state": {
    "current_player": 0,
    "priority_player": 0,
    "turn_number": 8,
    "phase": "normal_turn",
    "players": [
      {
        "player_id": 0,
        "remaining_mp": 2,
        "deck": [ "secret_deck_card_token" ],
        "hand": [ "secret_hand_card_token" ],
        "discard": [ "secret_discard_card_token" ]
      },
      { "player_id": 1, "remaining_mp": 0 }
    ],
    "units": [
      { "id": 1, "owner_id": 0, "card_id": "fixture_source", "x": 4, "y": 4, "hp": 5, "max_hp": 5 },
      { "id": 2, "owner_id": 1, "card_id": "fixture_target", "x": 5, "y": 4, "hp": 5, "max_hp": 5 }
    ],
    "walls": [],
    "statuses_by_unit": {}
  },
  "expected": {
    "ok": true,
    "expected_trace_order": [ "effect_request_resolved", "damage_effect_resolved", "heal_effect_resolved" ],
    "final_units": [
      { "id": 1, "x": 4, "y": 4, "hp": 5, "max_hp": 5, "statuses": [] },
      { "id": 2, "x": 5, "y": 4, "hp": 4, "max_hp": 5, "statuses": [] }
    ],
    "trace_fields": [
      { "kind": "effect_request_resolved", "target_unit_id": 2 },
      { "kind": "damage_effect_resolved", "target_unit_id": 2, "previous_hp": 5, "new_hp": 3 },
      { "kind": "heal_effect_resolved", "target_unit_id": 2, "previous_hp": 3, "new_hp": 4, "effective_heal_amount": 1 }
    ]
  },
  "expected_json": {
    "unit_id": 2,
    "hp": 4,
    "max_hp": 5,
    "forbidden_substrings": [
      "secret_deck_card_token",
      "secret_hand_card_token",
      "secret_discard_card_token",
      "secret_source_card_token",
      "secret_source_effect_token",
      "\"deck\"",
      "\"hand\"",
      "\"discard\"",
      "pending_attack"
    ]
  }
}
