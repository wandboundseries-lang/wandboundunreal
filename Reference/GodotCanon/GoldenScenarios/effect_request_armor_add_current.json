    },
    "target": {
      "target_unit_id": 2
    },
    "payloads": [
      {
        "operation": "armor_effect",
        "armor_effect": {
          "operation": "add_current_armor",
          "amount": 2,
          "source_reason": "fixture"
        }
      }
    ]
  },
  "initial_state": {
    "current_player": 0,
    "priority_player": 0,
    "turn_number": 7,
    "phase": "normal_turn",
    "players": [
      { "player_id": 0, "remaining_mp": 2 },
      { "player_id": 1, "remaining_mp": 0 }
