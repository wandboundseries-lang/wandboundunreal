        "kind": "effect_request_resolved",
        "player_id": 0,
        "source_unit_id": 1,
        "target_unit_id": 2
      },
      {
        "kind": "armor_modified",
        "target_unit_id": 2,
        "player_id": 1,
        "previous_armor": 1,
        "new_armor": 3,
        "previous_max_armor": 3,
        "new_max_armor": 3,
        "armor_effect_operation": "add_current_armor",
        "armor_effect_amount": 2
      }
