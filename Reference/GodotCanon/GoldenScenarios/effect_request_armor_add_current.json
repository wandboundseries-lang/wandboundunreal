  "godot_reference": [
    "scripts/sim/effect_runner.gd:resolve_card_effects",
    "scripts/sim/effects/handlers/modify_stat_handler.gd"
  ],
  "intent": "A generic effect request can route an armor add-current payload to the Unreal armor effect runner.",
  "operation": "apply_effect_request",
