{
  "id": "card_definition_build_and_apply_mixed_activation",
  "schema_version": 1,
  "godot_reference": [
    "scripts/data/CardDB/",
    "autoload/Game.gd",
    "scripts/sim/effect_runner.gd"
  ],
  "intent": "A fixture-owned card definition can build and apply an ordered mixed generic activation payload.",
  "operation": "build_and_apply_card_activation_command",
  "card_definition": {
    "card_id": "fixture_mixed_card",
    "public_name": "Fixture Mixed",
    "kind": "fixture",
    "activated_effects": [
      {
        "effect_id": "mixed_unit_effect",
        "public_label": "Mixed Unit Effect",
        "target_requirement": "unit",
        "payloads": [
          {
            "operation": "armor_effect",
            "armor_effect": { "operation": "add_current_armor", "amount": 2, "source_reason": "fixture" }
          },
          {
            "operation": "status_effect",
            "status_effect": { "operation": "apply_status", "status_id": "Burn", "duration": 2, "source_reason": "fixture" }
          },
          {
            "operation": "damage_effect",
            "damage_effect": { "amount": 1, "bypass_armor": true, "damage_cause": "Effect", "source_reason": "fixture" }
          },
          {
            "operation": "heal_effect",
            "heal_effect": { "amount": 2, "source_reason": "fixture" }
          }
        ]
      }
    ]
  },
  "activation_request": {
    "player_id": 0,
    "source_unit_id": 1,
    "effect_id": "mixed_unit_effect",
    "target": { "target_unit_id": 2 },
    "debug_activation_id": "fixture_mixed_activation"
  },
  "initial_state": {
    "current_player": 0,
    "priority_player": 0,
    "turn_number": 9,
    "phase": "normal_turn",
    "players": [
      { "player_id": 0, "remaining_mp": 2 },
      { "player_id": 1, "remaining_mp": 0 }
    ],
    "units": [
      { "id": 1, "owner_id": 0, "card_id": "fixture_source", "x": 4, "y": 4, "hp": 5, "max_hp": 5 },
      { "id": 2, "owner_id": 1, "card_id": "fixture_target", "x": 5, "y": 4, "hp": 4, "max_hp": 6, "current_armor": 0, "max_armor": 3 }
    ],
    "walls": [],
    "statuses_by_unit": {}
  },
  "expected": {
    "ok": true,
    "expected_trace_order": [ "card_activation_resolved", "effect_request_resolved", "armor_modified", "status_modified", "damage_effect_resolved", "heal_effect_resolved" ],
    "final_units": [
      { "id": 1, "x": 4, "y": 4, "hp": 5, "max_hp": 5, "statuses": [] },
      { "id": 2, "x": 5, "y": 4, "hp": 5, "max_hp": 6, "current_armor": 2, "max_armor": 3, "statuses": [ "Burn" ], "status_turns": { "Burn": 2 } }
    ],
    "trace_fields": [
      { "kind": "card_activation_resolved", "player_id": 0, "source_unit_id": 1, "target_unit_id": 2 },
      { "kind": "effect_request_resolved", "player_id": 0, "source_unit_id": 1, "target_unit_id": 2 },
      { "kind": "armor_modified", "target_unit_id": 2, "previous_armor": 0, "new_armor": 2 },
      { "kind": "status_modified", "target_unit_id": 2, "status_id": "Burn", "new_status_turns": 2 },
      { "kind": "damage_effect_resolved", "player_id": 0, "source_unit_id": 1, "target_unit_id": 2, "damage_amount": 1, "previous_hp": 4, "new_hp": 3 },
      { "kind": "heal_effect_resolved", "player_id": 0, "source_unit_id": 1, "target_unit_id": 2, "previous_hp": 3, "new_hp": 5, "effective_heal_amount": 2 }
    ]
  }
}
