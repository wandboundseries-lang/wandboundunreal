{
  "id": "effect_request_damage_effect_basic",
  "schema_version": 1,
  "godot_reference": [
    "scripts/sim/effect_runner.gd:damage",
    "scripts/sim/game_state.gd:apply_damage"
  ],
  "intent": "A generic effect request can route a damage_effect payload to the Unreal damage effect runner.",
  "operation": "apply_effect_request",
  "effect_request": {
    "source": {
      "player_id": 0,
      "source_unit_id": 1,
      "source_card_id": "secret_fixture_damage_card",
      "source_effect_id": "secret_fixture_damage_effect"
    },
    "target": { "target_unit_id": 2 },
    "payloads": [
      {
        "operation": "damage_effect",
        "damage_effect": {
          "amount": 2,
          "bypass_armor": false,
          "damage_cause": "Effect",
          "source_reason": "fixture"
        }
      }
    ]
  },
  "initial_state": {
    "current_player": 0,
    "priority_player": 0,
    "turn_number": 8,
    "phase": "normal_turn",
    "players": [
      { "player_id": 0, "remaining_mp": 2 },
      { "player_id": 1, "remaining_mp": 0 }
    ],
    "units": [
      { "id": 1, "owner_id": 0, "card_id": "fixture_source", "x": 4, "y": 4, "hp": 5, "max_hp": 5 },
      { "id": 2, "owner_id": 1, "card_id": "fixture_target", "x": 5, "y": 4, "hp": 5, "max_hp": 5 }
    ],
    "walls": [],
    "statuses_by_unit": {}
  },
  "expected": {
    "ok": true,
    "expected_trace_order": [ "effect_request_resolved", "damage_effect_resolved" ],
    "final_units": [
      { "id": 1, "x": 4, "y": 4, "hp": 5, "max_hp": 5, "statuses": [] },
      { "id": 2, "x": 5, "y": 4, "hp": 3, "max_hp": 5, "statuses": [] }
    ],
    "trace_fields": [
      { "kind": "effect_request_resolved", "player_id": 0, "source_unit_id": 1, "target_unit_id": 2 },
      { "kind": "damage_effect_resolved", "player_id": 0, "source_unit_id": 1, "target_unit_id": 2, "damage_amount": 2, "previous_hp": 5, "new_hp": 3 }
    ]
  }
}
