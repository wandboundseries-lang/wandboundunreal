    "usage": { "player_id": 0, "usage_key": "fixture_usage_success_key", "marked": true },
    "final_units": [
      { "id": 1, "x": 4, "y": 4, "hp": 5, "max_hp": 5, "statuses": [] },
      { "id": 2, "x": 5, "y": 4, "hp": 5, "max_hp": 6, "statuses": [] }
