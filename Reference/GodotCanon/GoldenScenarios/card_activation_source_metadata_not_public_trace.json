{
  "id": "card_activation_source_metadata_not_public_trace",
  "schema_version": 1,
  "godot_reference": [
    "autoload/Game.gd",
    "scripts/sim/effect_runner.gd"
  ],
  "intent": "Card activation source card/effect/debug metadata and hidden zones must not appear in traces or runtime public serialization.",
  "operation": "apply_card_activation_command",
  "card_activation": {
    "source": {
      "player_id": 0,
      "source_unit_id": 1,
      "source_card_id": "secret_activation_source_card_token",
      "source_effect_id": "secret_activation_source_effect_token"
    },
    "debug_activation_id": "secret_activation_debug_token",
    "effect_request": {
      "target": { "target_unit_id": 2 },
      "payloads": [
        {
          "operation": "damage_effect",
          "damage_effect": { "amount": 2, "bypass_armor": false, "damage_cause": "Effect", "source_reason": "fixture" }
        },
        {
          "operation": "heal_effect",
          "heal_effect": { "amount": 1, "source_reason": "fixture" }
        }
      ]
    }
  },
  "initial_state": {
    "current_player": 0,
    "priority_player": 0,
    "turn_number": 9,
    "phase": "normal_turn",
    "players": [
      {
        "player_id": 0,
        "remaining_mp": 2,
        "deck": [ "secret_activation_deck_token" ],
        "hand": [ "secret_activation_hand_token" ],
        "discard": [ "secret_activation_discard_token" ]
      },
      { "player_id": 1, "remaining_mp": 0 }
    ],
    "units": [
      { "id": 1, "owner_id": 0, "card_id": "fixture_source", "x": 4, "y": 4, "hp": 5, "max_hp": 5 },
      { "id": 2, "owner_id": 1, "card_id": "fixture_target", "x": 5, "y": 4, "hp": 5, "max_hp": 5 }
    ],
    "walls": [],
    "statuses_by_unit": {}
  },
  "expected": {
    "ok": true,
    "expected_trace_order": [ "card_activation_resolved", "effect_request_resolved", "damage_effect_resolved", "heal_effect_resolved" ],
    "final_units": [
      { "id": 1, "x": 4, "y": 4, "hp": 5, "max_hp": 5, "statuses": [] },
      { "id": 2, "x": 5, "y": 4, "hp": 4, "max_hp": 5, "statuses": [] }
    ],
    "trace_fields": [
      { "kind": "card_activation_resolved", "player_id": 0, "source_unit_id": 1, "target_unit_id": 2 },
      { "kind": "effect_request_resolved", "player_id": 0, "source_unit_id": 1, "target_unit_id": 2 },
      { "kind": "damage_effect_resolved", "player_id": 0, "source_unit_id": 1, "target_unit_id": 2, "previous_hp": 5, "new_hp": 3 },
      { "kind": "heal_effect_resolved", "player_id": 0, "source_unit_id": 1, "target_unit_id": 2, "previous_hp": 3, "new_hp": 4 }
    ]
  },
  "expected_json": {
    "unit_id": 2,
    "hp": 4,
    "max_hp": 5,
    "forbidden_substrings": [
      "secret_activation_source_card_token",
      "secret_activation_source_effect_token",
      "secret_activation_debug_token",
      "secret_activation_deck_token",
      "secret_activation_hand_token",
      "secret_activation_discard_token",
      "\"deck\"",
      "\"hand\"",
      "\"discard\"",
      "pending_attack"
    ]
  }
}
