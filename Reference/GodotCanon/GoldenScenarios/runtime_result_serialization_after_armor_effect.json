{
  "id": "runtime_result_serialization_after_armor_effect",
  "schema_version": 1,
  "godot_reference": [
    "autoload/Game.gd:unit public snapshot",
    "scripts/sim/game_state.gd:set_current_armor"
  ],
  "intent": "Runtime-style public board serialization after an armor effect exposes updated public armor only.",
  "operation": "apply_armor_effect",
  "armor_effect_request": {
    "operation": "add_current_armor",
    "target_unit_id": 1,
    "amount": 2,
    "source_reason": "fixture"
  },
  "initial_state": {
    "current_player": 0,
    "priority_player": 0,
    "turn_number": 6,
    "phase": "normal_turn",
    "players": [
      { "player_id": 0, "remaining_mp": 2, "last_mp_roll": 2 },
      { "player_id": 1, "remaining_mp": 0, "last_mp_roll": 0 }
    ],
    "units": [
      { "id": 1, "owner_id": 0, "card_id": "test_armored_unit", "x": 4, "y": 4, "hp": 5, "max_hp": 5, "current_armor": 1, "max_armor": 3 }
    ],
    "walls": [],
    "statuses_by_unit": {}
  },
  "expected": {
    "ok": true,
    "expected_trace_order": [ "armor_modified" ],
    "final_units": [
      { "id": 1, "x": 4, "y": 4, "hp": 5, "max_hp": 5, "current_armor": 3, "max_armor": 3, "statuses": [] }
    ],
    "trace_fields": [
      {
        "kind": "armor_modified",
        "target_unit_id": 1,
        "player_id": 0,
        "previous_armor": 1,
        "new_armor": 3,
        "previous_max_armor": 3,
        "new_max_armor": 3,
        "armor_effect_operation": "add_current_armor",
        "armor_effect_amount": 2
      }
    ]
  },
  "expected_json": {
    "selected_action_type": "armor_effect",
    "selected_action_id": "armor_effect:add_current_armor:u1",
    "ok": true,
    "trace_order": [ "armor_modified" ],
    "final_public_board_summary": {
      "units": [
        { "unit_id": 1, "x": 4, "y": 4, "hp": 5, "max_hp": 5, "current_armor": 3, "max_armor": 3 }
      ]
    },
    "forbidden_substrings": [ "deck", "hand", "discard", "pending_attack" ]
  }
}
